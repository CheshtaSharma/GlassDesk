# Gemini API
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# --- SQL Server (matches what you'd type into SSMS's connection dialog) ---
SQL_SERVER=localhost
SQL_DATABASE=your_database_name
# If using SQL Server Authentication, set both of these:
SQL_USERNAME=sa
SQL_PASSWORD=yourStrong(!)Password
# If using Windows Authentication instead, leave SQL_USERNAME/SQL_PASSWORD blank
# and set this to true.
SQL_TRUSTED_CONNECTION=false

# ODBC driver name as installed on your machine. Check with:
#   python -c "import pyodbc; print(pyodbc.drivers())"
SQL_DRIVER=ODBC Driver 17 for SQL Server

# --- Flask ---
FLASK_SECRET_KEY=your_secret_key
MAX_UPLOAD_MB=150